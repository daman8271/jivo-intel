# Copy to .env (chmod 600) and fill in. NEVER commit real secrets.
# Used by bin/auth.sh for unattended token refresh. If absent, the pipeline
# uses the CLI's already-stored token and alerts when it is near expiry.
JIVO_ECOM_EMAIL=ecom4@jivo.in
JIVO_ECOM_PASSWORD=
# Optional owner alerting (reuse existing Telegram helper if desired)
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=
GIT_REMOTE=
